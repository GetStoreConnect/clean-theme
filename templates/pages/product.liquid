{%- cache "product", items: [current_product, current_store, current_customer, current_cart] %}
  <div data-remote-target="product" class="sc-pos-relative">
    {%- render "shared/loader" %}
    {%- assign is_cpq_bundle = current_product.bundle_lead? %}
    {%- assign is_bundle = current_product.is_bundle? %}

    {%- liquid
        assign is_bundle = current_product.bundle_lead?
        assign tabs_content = "" | split: ""

        if current_product.features_content != blank
          assign tabs_content = tabs_content | push: current_product.features_content
        endif

        if current_product.specifications_content != blank
          assign tabs_content = tabs_content | push: current_product.specifications_content
        endif

        if current_product.downloads_content != blank
          assign tabs_content = tabs_content | push: current_product.downloads_content
        endif
    -%}

    <div>
      <div class="sc-container sc-me" id="SC-product-{{ current_product.slug }}">
        {%- render "breadcrumbs" %}

        <section class="SC-ProductDisplay{% if is_bundle %} ProductDisplay-bundle{% endif %}" id="SC-ProductDisplay">
          {%# Images %}
          <div class="SC-ProductDisplay_images" id="SC-ProductDisplayImages">
            {%- render "products/product/images", product: current_product %}
          </div>

          <div class="SC-ProductDisplay_details sc-flex-col sc-gap-small" id="SC-ProductDisplayDetails">
            <header class="sc-flex-col sc-gap-small">
              {%# Brand %}
              {%- if current_product.brand %}
                <div>{{ current_product.brand.name }}</div>
              {%- endif %}

              {%# Name %}
              <div>
                <h1 class="sc-m-none">{{ current_product.name }}</h1>
                {%- if current_product.discontinued? %}
                  {{ "products.show.discontinued" | t }}
                {%- endif %}
              </div>

              {%# Code %}
              <div class="sc-font-small sc-shade-dark">
                {{ current_product.product_code }}
              </div>

              {%# Price %}
              {%- unless is_bundle %}
                {% render "products/product/price", product: current_product %}
              {%- endunless %}

              {%# Out of stock %}
              {%- if current_product.out_of_stock? %}
                <div class="sc-color-error sc-font-medium sc-mb">
                  {{ current_product.out_of_stock_text }}
                </div>
              {%- endif %}

              {%# Restricted %}
              {%- if current_product.restricted? %}
                {% render "products/restricted", product: current_product %}
              {%- endif %}

              {%- if is_bundle == false and current_product.available_only_in_bundle? == false %}
                {%# Variant Selector %}
                {% render "products/product/variant_selector", product: current_product %}

                {%# Add to cart %}
                <div class="sc-mb">
                  {% render "products/product/add_to_cart", product: current_product %}
                </div>

                {%# Summary %}
                <div class="sc-mb sc-mt">
                  <div>{{ current_product.summary_content }}</div>
                  {%# Tax exclusion %}
                  {%- unless current_product.pricing.hide_price? or current_product.pricing.tax_inclusive? or current_product.restricted_text %}
                    {% if current_product.pricing.price > 0 %}
                      <div class="SC-ExcludesTax">
                        {{ "products.show.excluding_tax" | t }}
                      </div>
                    {% endif %}
                  {% endunless %}
                </div>
              {%- endif %}

              {%- if current_product.available_only_in_bundle? %}
                <div class="bundle-only-notice sc-mb">
                  <div class="sc-color-warning sc-font-small sc-mb-small">
                    {{ "products.bundle_only.notice" | t }}
                  </div>

                  {%- assign contained_in_bundles = current_product.contained_in_bundles %}
                  {%- if contained_in_bundles.size > 0 %}
                    <div class="available-bundles">
                      <h4 class="sc-font-small sc-mb-small">{{ "products.bundle_only.available_in" | t }}:</h4>
                      <ul class="sc-list-unstyled">
                        {%- for bundle in contained_in_bundles %}
                          <li class="sc-mb-small">
                            <a href="{{ bundle.path }}" class="SC-Button SC-Button-secondary SC-Button-small">
                              {{ bundle.name }}
                            </a>
                          </li>
                        {%- endfor %}
                      </ul>
                    </div>
                  {%- endif %}
                </div>
              {%- endif %}
            </header>

            {%# Bundle configuration %}
            {%- if is_bundle %}
              {%- if is_cpq_bundle %}
                {%- require "scripts/bundle.js" -%}
                {%- require "scripts/quantity-picker.js" -%}

                {%# Price %}
                {% if current_product.pricing.has_price? %}
                  <div data-bundle-price></div>
                {% endif %}

                {%# Product options %}
                <section id="SC-BundleProducts" class="sc-pos-relative" style="min-height: 300px">
                  <div data-bundle="{{ current_product.id }}" class="sc-flex-col sc-gap">
                    {%- render "shared/loader", active: true %}
                    {{ "products.show.loading_bundles" | t }}
                  </div>
                </section>
              {%- else %}
                {%- comment -%} Bundle V2 Implementation {%- endcomment -%}
                {%- require "scripts/bundle-v2.js" -%}
                {%- require "scripts/quantity-picker.js" -%}

                {%- comment -%} Detect edit mode from URL parameters {%- endcomment -%}
                {%- assign bundle_identifier_param = current_request.params.bundle_identifier -%}
                {%- assign bundle_config_param = current_request.params.bundle_config -%}

                <div data-bundle-price>
                  {%- render "products/product/bundle/pricing_display", product: current_product %}
                </div>

                <section id="SC-BundleProducts" class="sc-pos-relative">
                  <div data-bundle="{{ current_product.id }}" data-bundle-type="v2" class="sc-flex-col sc-gap">
                    {%- render "products/product/bundle/bundle_configurator",
                                product: current_product,
                                bundle_config_param: bundle_config_param,
                                bundle_identifier: bundle_identifier_param %}
                  </div>
                </section>
              {%- endif %}
            {%- elsif current_product.available_only_in_bundle? == false %}
              {%# Delivery and pickup %}
              <div class="sc-mb">
                {%- render "products/product/inventory", product: current_product %}
              </div>

              {%# Warranty %}
              {%- render "products/product/warranty", product: current_product %}

              {%# Support %}
              {%- render "products/product/support", product: current_product %}

              {%# Downloads %}
              {%- if tabs_content.size <= 1 %}
                {%- render "products/product/downloads", product: current_product %}
              {%- endif %}
            {%- endif %}
          </div>
        </section>

        {%- if is_bundle %}
          {%- if is_cpq_bundle %}
            <div data-bundle-anchor-variants></div>
          {%- else %}
            <div data-bundle-anchor-variants>
              {% render "products/product/bundle/anchor_variants", product: current_product %}
            </div>
          {%- endif %}
        {%- else %}
          {%# Features %}
          {%- capture features_content -%}
            {%- if current_product.features_content != blank %}
              <section class="SC-ProductFeatures sc-p-base sc-hide" data-tab="sc-features-section">
                <div class="sc-rich-text sc-mb">
                  <div>
                    {{ current_product.features_content }}
                  </div>
                </div>
              </section>
            {%- endif %}
          {%- endcapture -%}

          {%# Specifications %}
          {%- capture specifications_content -%}
            {%- if current_product.specifications_content != blank %}
              <section class="SC-ProductSpecifications sc-p-base sc-hide" data-tab="sc-specifications-section">
                <div class="sc-rich-text sc-mb">
                  <div>
                    {{ current_product.specifications_content }}
                  </div>
                </div>
              </section>
            {%- endif %}
          {%- endcapture %}

          {%- capture downloads_content -%}
            {%- if current_product.downloads_content != blank %}
              <section class="SC-ProductDownloads sc-p-base sc-hide" data-tab="sc-downloads-section">
                <div class="sc-rich-text sc-mb">
                  <div>
                    {{ current_product.downloads_content }}
                  </div>
                </div>
              </section>
            {%- endif %}
          {%- endcapture -%}

          <div class="sc-mb-spacious" class="SC-ProductContentBlocks" id="SC-ProductContentBlocks">
            {%- if tabs_content.size > 1 %}
              <div class="SC-Tabs sc-shadow-2" data-tabs="{{ current_product.identifier }}">
                <div class="SC-Tab_buttons sc-flex">
                  {%- if current_product.features_content != blank %}
                    <button class="SC-Tab_button" type="button" data-tab-trigger="sc-features-section">{{ current_product.features_label }}</button>
                  {%- endif %}
                  {%- if current_product.specifications_content != blank %}
                    <button class="SC-Tab_button" type="button" data-tab-trigger="sc-specifications-section">{{ current_product.specifications_label }}</button>
                  {%- endif %}
                  {%- if current_product.downloads_content != blank %}
                    <button class="SC-Tab_button" type="button" data-tab-trigger="sc-downloads-section">{{ current_product.downloads_label }}</button>
                  {%- endif %}
                </div>
                <div class="SC-Tab_content">
                  {{ features_content }}
                  {{ specifications_content }}
                  {{ downloads_content }}
              </div>
            </div>
            {%- else %}
              {{ features_content }}
              {{ specifications_content }}
            {%- endif %}
          </div>
        {%- endif %}

        {% render "products/product/rich_data_json", product: current_product %}

        {%# Related products %}
        <section class="sc-mb">
          {% render "products/related_products", product: current_product %}
        </section>
      </div>
    </div>
  </div>
{%- endcache %}
